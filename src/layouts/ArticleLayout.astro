---
import BaseLayout from './BaseLayout.astro';
import LanguageBadge from '../components/LanguageBadge.astro';
import TagList from '../components/TagList.astro';

interface Props {
  title: string;
  date: Date;
  lang: 'fr' | 'en';
  tags: string[];
  description?: string;
}

const { title, date, lang, tags, description } = Astro.props;

const formattedDate = date.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-base-900">
        {title}
      </h1>

      <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-base-700">
        <time datetime={date.toISOString().split('T')[0]}>
          {formattedDate}
        </time>

        <LanguageBadge lang={lang} />

        <TagList tags={tags} />
      </div>
    </header>

    <div class="prose max-w-prose">
      <slot />
    </div>
  </article>
</BaseLayout>

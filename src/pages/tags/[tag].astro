---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import TagList from '../../components/TagList.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allArticles = await getCollection('articles', ({ data }) => data.draft !== true);

  const tagMap = new Map<string, typeof allArticles>();

  for (const article of allArticles) {
    for (const rawTag of article.data.tags) {
      const tag = rawTag.toLowerCase();
      if (!tagMap.has(tag)) {
        tagMap.set(tag, []);
      }
      tagMap.get(tag)!.push(article);
    }
  }

  return [...tagMap.entries()].map(([tag, articles]) => ({
    params: { tag },
    props: {
      articles: articles.sort(
        (a, b) => b.data.date.getTime() - a.data.date.getTime()
      ),
    },
  }));
}

const { tag } = Astro.params;
const { articles } = Astro.props;

const allArticles = await getCollection('articles', ({ data }) => data.draft !== true);
const allTags = [
  ...new Set(
    allArticles.flatMap((article) =>
      article.data.tags.map((t) => t.toLowerCase())
    )
  ),
].sort();
---

<BaseLayout title={`Tag : ${tag}`}>
  <a
    href="/ecrits"
    class="inline-flex items-center text-sm text-base-700 no-underline transition-colors hover:text-accent-600"
  >
    &larr; Tous les ecrits
  </a>

  <h1 class="mt-4 text-3xl font-bold tracking-tight text-base-900">
    Tag : {tag}
  </h1>

  <p class="mt-2 text-base-700">
    {articles.length} {articles.length > 1 ? 'articles' : 'article'}
  </p>

  {allTags.length > 0 && (
    <nav class="mt-6">
      <TagList tags={allTags} />
    </nav>
  )}

  {articles.length > 0 ? (
    <div class="mt-8 space-y-8">
      {articles.map((article) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          date={article.data.date}
          lang={article.data.lang}
          tags={article.data.tags}
          slug={article.id}
        />
      ))}
    </div>
  ) : (
    <p class="mt-4 text-base-700">Aucun article pour ce tag.</p>
  )}
</BaseLayout>

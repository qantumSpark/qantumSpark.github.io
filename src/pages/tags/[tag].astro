---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import TagList from '../../components/TagList.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allArticles = await getCollection('articles', ({ data }) => data.draft !== true);

  const tagMap = new Map<string, typeof allArticles>();

  for (const article of allArticles) {
    for (const rawTag of article.data.tags) {
      const tag = rawTag.toLowerCase();
      if (!tagMap.has(tag)) {
        tagMap.set(tag, []);
      }
      tagMap.get(tag)!.push(article);
    }
  }

  return [...tagMap.entries()].map(([tag, articles]) => ({
    params: { tag },
    props: {
      articles: articles.sort(
        (a, b) => b.data.date.getTime() - a.data.date.getTime()
      ),
    },
  }));
}

const { tag } = Astro.params;
const { articles } = Astro.props;

const allArticles = await getCollection('articles', ({ data }) => data.draft !== true);
const allTags = [
  ...new Set(
    allArticles.flatMap((article) =>
      article.data.tags.map((t) => t.toLowerCase())
    )
  ),
].sort();
---

<BaseLayout title={`Tag : ${tag}`}>
  <a
    href="/ecrits"
    class="inline-flex items-center text-xs uppercase tracking-wider text-text-muted no-underline transition-colors hover:text-glow-cyan"
    style="font-family: var(--font-mono);"
  >
    &larr; Tous les ecrits
  </a>

  <h1 class="mt-4 animate-fade-in-up text-4xl font-extrabold tracking-tight" style="font-family: var(--font-heading);">
    Tag : <span class="text-glow-cyan">{tag}</span>
  </h1>

  <p class="mt-2 text-text-secondary" style="font-family: var(--font-mono); font-size: 0.75rem;">
    {articles.length} {articles.length > 1 ? 'articles' : 'article'}
  </p>

  {allTags.length > 0 && (
    <nav class="mt-6 animate-fade-in-up" style="animation-delay: 0.1s;">
      <TagList tags={allTags} activeTag={tag} />
    </nav>
  )}

  {articles.length > 0 ? (
    <div class="mt-8 space-y-6">
      {articles.map((article, i) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          date={article.data.date}
          lang={article.data.lang}
          tags={article.data.tags}
          slug={article.id}
          index={i}
        />
      ))}
    </div>
  ) : (
    <p class="mt-4 text-text-secondary">Aucun article pour ce tag.</p>
  )}
</BaseLayout>

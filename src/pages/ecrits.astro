---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import TagList from '../components/TagList.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = allArticles
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allTags = [
  ...new Set(
    sortedArticles.flatMap((article) =>
      article.data.tags.map((tag) => tag.toLowerCase())
    )
  ),
].sort();

const articleCount = sortedArticles.length;
---

<BaseLayout title="Ecrits">
  <h1
    class="animate-fade-in-up text-4xl font-extrabold tracking-tight"
    style="font-family: var(--font-heading); background: linear-gradient(135deg, #00e5ff 0%, #e0e0ec 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
  >
    &#9672; Ecrits
  </h1>

  <p
    class="mt-2 animate-fade-in-up text-text-muted"
    style="font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; animation-delay: 0.05s;"
  >
    [{articleCount} ENTRIES]
  </p>

  {allTags.length > 0 && (
    <div class="mt-6 animate-fade-in-up" style="animation-delay: 0.1s;">
      <TagList tags={allTags} />
    </div>
  )}

  <!-- Separator between tags and articles -->
  <div class="mt-6 flex items-center gap-4" aria-hidden="true">
    <div class="h-px flex-1 bg-gradient-to-r from-transparent via-void-border to-transparent"></div>
  </div>

  {sortedArticles.length > 0 ? (
    <div class="mt-8 space-y-6">
      {sortedArticles.map((article, i) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          date={article.data.date}
          lang={article.data.lang}
          tags={article.data.tags}
          slug={article.id}
          index={i}
        />
      ))}
    </div>
  ) : (
    <p class="mt-4 text-text-secondary">Aucun article pour le moment.</p>
  )}
</BaseLayout>

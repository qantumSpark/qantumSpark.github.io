---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const latestArticles = allArticles
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);
---

<BaseLayout title="Accueil">
  <!-- Hero section -->
  <section class="mb-20 animate-fade-in-up">
    <h1
      class="text-5xl font-extrabold tracking-tight"
      style="font-family: var(--font-heading); background: linear-gradient(135deg, #00e5ff 0%, #e0e0ec 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
    >
      Bienvenue
    </h1>
    <p class="mt-5 text-lg font-light leading-relaxed text-text-secondary">
      Cet espace rassemble mes reflexions, essais et projets autour de
      l'ecriture, de la technologie et de la pensee critique. Un lieu sobre,
      fait pour lire et explorer.
    </p>

    <!-- Sci-fi separator -->
    <div class="mt-8 flex items-center gap-4" aria-hidden="true">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent to-glow-cyan-border"></div>
      <div class="h-2 w-2 rotate-45 border border-glow-cyan-border bg-transparent"></div>
      <div class="h-px flex-1 bg-gradient-to-l from-transparent to-glow-cyan-border"></div>
    </div>
  </section>

  <!-- Latest writings -->
  <section>
    <h2
      class="text-xs uppercase tracking-widest text-text-muted"
      style="font-family: var(--font-mono);"
    >
      // Derniers ecrits
    </h2>

    {latestArticles.length > 0 ? (
      <div class="mt-8 space-y-6">
        {latestArticles.map((article, i) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            date={article.data.date}
            lang={article.data.lang}
            tags={article.data.tags}
            slug={article.id}
            index={i}
          />
        ))}
      </div>
    ) : (
      <p class="mt-4 text-text-secondary">Aucun article pour le moment.</p>
    )}

    {latestArticles.length > 0 && (
      <div class="mt-10">
        <a
          href="/ecrits"
          class="inline-flex items-center gap-2 text-sm font-medium text-glow-cyan no-underline transition-all hover:text-glow-cyan"
          style="font-family: var(--font-mono);"
        >
          Voir tous les ecrits &rarr;
        </a>
      </div>
    )}
  </section>
</BaseLayout>

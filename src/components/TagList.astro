---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{tags.length > 0 && (
  <div class="inline-flex flex-wrap gap-2">
    {tags.map((tag) => (
      <a
        href={`/tags/${tag.toLowerCase()}`}
        class="inline-flex items-center rounded-sm border border-glow-cyan-border bg-transparent px-2.5 py-1 text-xs uppercase tracking-wider text-text-secondary no-underline transition-all hover:border-glow-cyan/40 hover:bg-glow-cyan-ghost hover:text-glow-cyan-dim"
        style="font-family: var(--font-mono);"
      >
        <span class="mr-1 text-text-muted">#</span>{tag}
      </a>
    ))}
  </div>
)}

---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-glow-cyan-border/50 bg-transparent">
  <div class="mx-auto flex max-w-3xl flex-wrap items-center justify-between gap-x-8 gap-y-2 px-6 py-4">
    <p class="text-xs text-text-muted" style="font-family: var(--font-mono);">
      &gt; SYS.{currentYear} // ALL RIGHTS RESERVED
    </p>
    <a
      href="https://github.com"
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs text-text-muted no-underline transition-colors hover:text-glow-cyan"
      style="font-family: var(--font-mono);"
    >
      SOURCE::GITHUB
    </a>
  </div>
</footer>

---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-base-200 bg-base-50">
  <div class="mx-auto flex max-w-2xl flex-wrap items-center justify-between gap-x-8 gap-y-2 px-6 py-4">
    <p class="text-sm text-base-700">
      &copy; {currentYear} Site personnel. Tous droits reserves.
    </p>
    <a
      href="https://github.com"
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm text-base-700 no-underline hover:text-accent-600 transition-colors"
    >
      Source sur GitHub
    </a>
  </div>
</footer>

---
import LanguageBadge from './LanguageBadge.astro';
import TagList from './TagList.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  lang: string;
  tags: string[];
  slug: string;
}

const { title, description, date, lang, tags, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="border-b border-base-200 pb-8">
  <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-base-700">
    <time datetime={date.toISOString().split('T')[0]}>
      {formattedDate}
    </time>
    <LanguageBadge lang={lang} />
  </div>

  <h2 class="mt-2 text-xl font-bold tracking-tight text-base-900">
    <a
      href={`/ecrits/${slug}`}
      class="no-underline transition-colors hover:text-accent-600"
    >
      {title}
    </a>
  </h2>

  <p class="mt-2 text-base-700 leading-relaxed">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="mt-3">
      <TagList tags={tags} />
    </div>
  )}
</article>

---
import LanguageBadge from './LanguageBadge.astro';
import TagList from './TagList.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  lang: string;
  tags: string[];
  slug: string;
  index?: number;
}

const { title, description, date, lang, tags, slug, index = 0 } = Astro.props;

const formattedDate = date.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const delay = index * 0.08;
---

<article
  class="animate-fade-in-up rounded-lg border border-void-border bg-void-light/50 p-6 backdrop-blur-sm transition-all duration-300 hover:border-glow-cyan-border hover:shadow-[0_0_20px_rgba(0,229,255,0.05)]"
  style={`animation-delay: ${delay}s;`}
>
  <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
    <time
      datetime={date.toISOString().split('T')[0]}
      class="text-text-muted"
      style="font-family: var(--font-mono); font-size: 0.75rem;"
    >
      {formattedDate}
    </time>
    <LanguageBadge lang={lang} />
  </div>

  <h2 class="mt-3 text-xl font-semibold tracking-tight text-text-primary" style="font-family: var(--font-heading);">
    <a
      href={`/ecrits/${slug}`}
      class="no-underline text-text-primary transition-colors duration-200 hover:text-glow-cyan"
    >
      {title}
    </a>
  </h2>

  <p class="mt-2 text-text-secondary leading-relaxed">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="mt-4">
      <TagList tags={tags} />
    </div>
  )}
</article>

---
interface Props {
  lang: string;
}

const { lang } = Astro.props;

const isFr = lang.toLowerCase() === 'fr';
const label = isFr ? 'FR' : 'EN';
---

<span
  class:list={[
    "inline-block rounded-sm px-2 py-0.5 text-xs font-medium uppercase tracking-wider bg-transparent",
    isFr
      ? "border border-glow-cyan-border text-glow-cyan-dim"
      : "border border-glow-amber/30 text-glow-amber-dim",
  ]}
  style="font-family: var(--font-mono);"
>
  {label}
</span>
